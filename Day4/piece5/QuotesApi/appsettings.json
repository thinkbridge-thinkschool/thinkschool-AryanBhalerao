{
  "ConnectionStrings": {
    "Default": "Data Source=quotes.db"
  },
  "Jwt": {
    "Key": "QuotesApi-Dev-SigningKey-ChangeThisInProduction-MustBe32BytesMin",
    "Issuer": "QuotesApi",
    "Audience": "QuotesApi",
    "ExpiresInMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "AzureAd": {
    "TenantId": "7e394fc8-4b86-4cfe-810e-43f86f8bec47",
    "ClientId": "cbd99da1-dee1-4a9c-9f82-16ffc5bb486e"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {TraceId} {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
